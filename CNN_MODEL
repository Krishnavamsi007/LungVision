        "import os\n",
        "import cv2\n",
        "import numpy as np\n",
        "from sklearn.model_selection import train_test_split\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Define parameters\n",
        "IMG_SIZE = 128  # Resize images to 128x128\n",
        "categories = ['Normal cases', 'Bengin cases', 'Malignant cases']  # Corrected class labels\n",
        "data = []  # To store image data in numpy image pixel values are stored in form of array grayscale will have 0-255 pixel values\n",
        "labels = []  # To store corresponding labels\n",
        "\n",
        "# Path to  dataset folder in Google Drive\n",
        "dataset_path = '/content/drive/MyDrive/LungCancerDataset/'\n",
        "\n",
        "# Check folder structure\n",
        "print(\"Folders in dataset:\", os.listdir(dataset_path))\n",
        "\n",
        "# Load the dataset\n",
        "for category in categories:\n",
        "    path = os.path.join(dataset_path, category)  # Path to class folders\n",
        "    if not os.path.exists(path):\n",
        "        print(f\"Folder not found: {path}\")\n",
        "        continue  # Skip if folder doesn't exist\n",
        "\n",
        "    class_num = categories.index(category)  # 0 for normal, 1 for benign, 2 for malignant\n",
        "\n",
        "    for img_name in os.listdir(path):\n",
        "        try:\n",
        "            img_path = os.path.join(path, img_name)\n",
        "            img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)  # Load image in grayscale\n",
        "            img = cv2.resize(img, (IMG_SIZE, IMG_SIZE))  # Resize image to 128x128\n",
        "            data.append(img)  # Append image data\n",
        "            labels.append(class_num)  # Append the class label\n",
        "        except Exception as e:\n",
        "            print(f\"Error reading {img_path}: {e}\")#occurs when image is corrupted\n",
        "\n",
        "# Convert lists to NumPy arrays\n",
        "data = np.array(data).reshape(-1, IMG_SIZE, IMG_SIZE, 1) / 255.0  # Normalize images to [0, 1]\n",
        "labels = np.array(labels)\n",
        "\n",
        "# Split into train and test sets (80% training, 20% testing)\n",
        "x_train, x_test, y_train, y_test = train_test_split(data, labels, test_size=0.2, stratify=labels)#equal distibution of classes in 2 sets stratify=labels\n",
        "\n",
        "# Check the shapes\n",
        "print(f\"x_train shape: {x_train.shape}\")#(no.of samples,height,width,number of channels)\n",
        "print(f\"x_test shape: {x_test.shape}\")\n",
        "print(f\"y_train shape: {y_train.shape}\")\n",
        "print(f\"y_test shape: {y_test.shape}\")\n",
        "\n",
        "# Visualize sample images from the training set\n",
        "fig, axes = plt.subplots(1, 5, figsize=(12, 12))#1 row 5 col\n",
        "\n",
        "for i, ax in enumerate(axes):\n",
        "    ax.imshow(x_train[i].reshape(IMG_SIZE, IMG_SIZE), cmap='gray')  # Display in grayscale\n",
        "    ax.set_title(categories[int(y_train[i])])  # Label the image (normal, benign, malignant)\n",
        "    ax.axis('off')\n",
        "\n",
        "plt.show()\n"
      ],
